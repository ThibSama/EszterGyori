{
  "name": "passe1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "auth:hash-password": "node scripts/generate-admin-password-hash.mjs",
    "build:contracts": "node --preserve-symlinks ./node_modules/typescript/bin/tsc -p ./node_modules/@eszter/contracts/tsconfig.json",
    "postinstall": "npm run build:contracts",
    "predev": "npm run build:contracts",
    "dev": "node --preserve-symlinks ./node_modules/next/dist/bin/next dev",
    "build": "npm run build:contracts && node --preserve-symlinks ./node_modules/next/dist/bin/next build",
    "start": "node --preserve-symlinks ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "test": "node --preserve-symlinks --conditions=react-server --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@eszter/contracts": "file:../contracts",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
